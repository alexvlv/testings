client
dev tun  
proto udp  
remote <IP> 1194
resolv-retry infinite  
nobind  
persist-key  
persist-tun  
remote-cert-tls server
key-direction 1
cipher AES-256-GCM  
auth SHA256
verb 3  
comp-lzo no

<ca>
${ca_crt}
</ca>
<cert>
${client_crt}
</cert>
<key>
${client_key}
</key>
<tls-auth>
${tls_auth}
</tls-auth>
